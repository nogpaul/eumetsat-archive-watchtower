# EUMETSAT Data Store credentials
# Get yours at: https://api.eumetsat.int/api-key
EUMETSAT_CONSUMER_KEY=replace-me
EUMETSAT_CONSUMER_SECRET=replace-me

# Watchtower configuration
WATCHTOWER_COLLECTIONS=EO:EUM:DAT:MSG:HRSEVIRI,EO:EUM:DAT:METOP:GLB-SST-NC
WATCHTOWER_POLL_INTERVAL_SECONDS=300
WATCHTOWER_DB_URL=sqlite:///./watchtower.db
WATCHTOWER_LOG_LEVEL=INFO